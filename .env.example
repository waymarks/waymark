# Waymark Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# Slack Integration (optional)
# Create a webhook at api.slack.com/apps
WAYMARK_SLACK_WEBHOOK_URL=
WAYMARK_SLACK_CHANNEL=#engineering

# Dashboard URL (used in Slack notifications)
WAYMARK_BASE_URL=http://localhost:3001

# Server Configuration (optional)
WAYMARK_PORT=3001
WAYMARK_DB_PATH=./data/waymark.db
