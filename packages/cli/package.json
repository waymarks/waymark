{
  "name": "@way_marks/cli",
  "version": "4.0.1",
  "description": "Control what AI agents can do in your codebase",
  "author": "Waymark <hello@waymarks.dev>",
  "license": "MIT",
  "homepage": "https://github.com/waymarks/waymark",
  "repository": {
    "type": "git",
    "url": "https://github.com/waymarks/waymark.git"
  },
  "bugs": {
    "url": "https://github.com/waymarks/waymark/issues"
  },
  "keywords": [
    "ai-agents",
    "claude-code",
    "mcp",
    "security",
    "developer-tools",
    "llm",
    "agent-control"
  ],
  "bin": {
    "waymark": "./dist/index.js",
    "way_marks": "./dist/index.js"
  },
  "files": [
    "dist/**",
    "scripts/postinstall.js"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "postinstall": "node scripts/postinstall.js"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.ts"
    ]
  },
  "dependencies": {
    "@way_marks/server": "4.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.11.5",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.3.3"
  }
}
